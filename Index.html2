import { useState, useRef, useEffect } from "react";

const PRODUCTS = [
  { name: "🎧 سماعات لاسلكية", price: 299, desc: "صوت احترافي + بطارية 20 ساعة" },
  { name: "⌚ ساعة ذكية", price: 499, desc: "تتبع صحة + GPS + مقاومة للماء" },
  { name: "🎒 حقيبة ظهر", price: 149, desc: "جلد فاخر + تصميم عصري" },
  { name: "🕶️ نظارة شمسية", price: 89, desc: "حماية UV + خفيفة الوزن" },
  { name: "🔋 شاحن لاسلكي", price: 69, desc: "شحن سريع 15W لكل الأجهزة" },
];

const SYSTEM_PROMPT = `
أنت مساعد متجر اسمه MALAK SHOP.
تتحدث العربية فقط وبأسلوب لطيف ومقنع.

المهمات:
- شرح المنتجات
- مساعدة العميل على الشراء
- إذا أراد الطلب، اجمع: الاسم، الهاتف، العنوان، المنتج

عند اكتمال الطلب اكتب:
ORDER_START
...
ORDER_END

ثم قل: تم تسجيل طلبك بنجاح ✅
`;

const WELCOME = `
مرحباً بك في ✨ MALAK SHOP

🛍️ أفضل المنتجات بأفضل الأسعار

اكتب لي ماذا تريد أو اسألني 👇
`;

function extractOrder(text) {
  const m = text.match(/ORDER_START([\s\S]*?)ORDER_END/);
  return m ? m[1].trim() : null;
}

function clean(text) {
  return text.replace(/ORDER_START[\s\S]*?ORDER_END/g, "");
}

export default function MalakShop() {
  const [messages, setMessages] = useState([
    { role: "assistant", content: WELCOME },
  ]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [order, setOrder] = useState(null);
  const bottomRef = useRef(null);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  const send = async () => {
    if (!input.trim() || loading) return;

    const userMsg = { role: "user", content: input };
    const newMessages = [...messages, userMsg];

    setMessages(newMessages);
    setInput("");
    setLoading(true);

    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-api-key": "YOUR_API_KEY",
        },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 800,
          system: SYSTEM_PROMPT,
          messages: newMessages,
        }),
      });

      const data = await res.json();
      const raw =
        data.content?.map((c) => c.text).join("") ||
        "حدث خطأ";

      const ord = extractOrder(raw);
      if (ord) setOrder(ord);

      setMessages((prev) => [
        ...prev,
        { role: "assistant", content: clean(raw) },
      ]);
    } catch {
      setMessages((prev) => [
        ...prev,
        { role: "assistant", content: "خطأ في الاتصال" },
      ]);
    }

    setLoading(false);
  };

  return (
    <div className="app">
      <div className="container">

        {/* HEADER */}
        <div className="header">
          <h1>✨ MALAK SHOP</h1>
          <p>أفضل تجربة تسوق ذكية</p>
        </div>

        {/* PRODUCTS */}
        <div className="products">
          {PRODUCTS.map((p, i) => (
            <div key={i} className="card">
              <h3>{p.name}</h3>
              <p>{p.desc}</p>
              <span>{p.price} ريال</span>
            </div>
          ))}
        </div>

        {/* CHAT */}
        <div className="chat">
          <div className="messages">
            {messages.map((m, i) => (
              <div
                key={i}
                className={m.role === "user" ? "user" : "bot"}
              >
                {m.content}
              </div>
            ))}
            <div ref={bottomRef} />
          </div>

          <div className="inputBox">
            <input
              value={input}
              onChange={(e) => setInput(e.target.value)}
              placeholder="اسأل عن أي منتج..."
            />
            <button onClick={send}>
              {loading ? "..." : "إرسال"}
            </button>
          </div>
        </div>

        {/* ORDER */}
        {order && (
          <div className="order">
            <h3>📦 طلب جديد</h3>
            <pre>{order}</pre>
          </div>
        )}
      </div>

      {/* STYLE */}
      <style>{`
        body {
          margin: 0;
          font-family: Arial;
          background: #0b0f19;
          color: white;
        }

        .container {
          max-width: 1000px;
          margin: auto;
          padding: 20px;
        }

        .header {
          text-align: center;
          padding: 20px;
        }

        .header h1 {
          color: #fbbf24;
        }

        .products {
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
          gap: 12px;
          margin: 20px 0;
        }

        .card {
          background: rgba(255,255,255,0.05);
          padding: 12px;
          border-radius: 12px;
          border: 1px solid rgba(255,255,255,0.1);
        }

        .card span {
          color: #4ade80;
          font-weight: bold;
        }

        .chat {
          background: rgba(255,255,255,0.03);
          border-radius: 16px;
          padding: 10px;
        }

        .messages {
          height: 300px;
          overflow-y: auto;
          padding: 10px;
        }

        .user {
          text-align: right;
          background: #d97706;
          padding: 8px;
          margin: 6px;
          border-radius: 10px;
        }

        .bot {
          text-align: left;
          background: rgba(255,255,255,0.08);
          padding: 8px;
          margin: 6px;
          border-radius: 10px;
        }

        .inputBox {
          display: flex;
          gap: 8px;
          margin-top: 10px;
        }

        input {
          flex: 1;
          padding: 10px;
          border-radius: 10px;
          border: none;
        }

        button {
          padding: 10px 15px;
          background: #f59e0b;
          border: none;
          border-radius: 10px;
          cursor: pointer;
        }

        .order {
          margin-top: 15px;
          background: rgba(74,222,128,0.1);
          padding: 10px;
          border-radius: 12px;
          border: 1px solid #4ade80;
        }
      `}</style>
    </div>
  );
}import MalakShop from "./MalakShop";

export default function App() {
  return <MalakShop />;
}
